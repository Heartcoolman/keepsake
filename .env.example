# xAI API key (https://console.x.ai) — required unless MOCK_AI=1
XAI_API_KEY=
# Optional OpenAI-compatible local gateway. When set, XAI_API_KEY may be empty.
AI_BASE_URL=
# Optional model name for the configured gateway.
AI_MODEL=
# Server port
PORT=8787
# Set to 1 to serve canned AI responses with zero API cost
MOCK_AI=0
# HMAC secret for /api/v1 JWT (min 16 chars). Generate: openssl rand -hex 32
JWT_SECRET=
# Local development only: allow an in-memory key when JWT_SECRET is unset.
# Never enable in production; docker-compose requires JWT_SECRET.
ALLOW_EPHEMERAL_JWT=0
# Optional shared secret for POST /api/v1/auth/bootstrap
# (header X-Bootstrap-Token or body.bootstrapToken). Recommended when :8787 is
# reachable before the first account exists (LAN / tunnel).
BOOTSTRAP_TOKEN=
# Optional gate for open registration (POST /api/v1/auth/register, header
# X-Registration-Code or body.regCode). Leave empty for open signup.
# NOTE: once the /ops console writes data/ops-config.json, that file replaces
# this variable entirely (including "no code required").
REGISTRATION_CODE=
# One-time token for creating the FIRST operator of the /ops console
# (POST /api/ops/auth/bootstrap). Only honored while zero operators exist —
# set it, bootstrap at /ops, then remove it. See docs/ops.md.
OPS_BOOTSTRAP_TOKEN=
# Number of trusted reverse-proxy hops in front of the server. 0 = ignore
# X-Forwarded-For/Proto (direct exposure). Set to the count of proxies that each
# append one entry (1 for a single proxy/tunnel); the client IP/proto is then read
# that many entries from the right, so client-spoofed leftmost entries are ignored.
TRUST_PROXY=0
